# Normalize line endings: LF in the repo for all text files.
* text=auto eol=lf

# Windows batch scripts need CRLF.
*.bat text eol=crlf

# The Gradle wrapper script MUST stay LF — it runs on Linux CI.
gradlew text eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jar binary
*.keystore binary
*.jks binary
